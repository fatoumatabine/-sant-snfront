@startuml SANTE_SN_Use_Cases_Secretaire
skinparam backgroundColor #FEFEFE
skinparam classBackgroundColor #F4F4F4

title SANTE SN - Cas d'Usage (Secretaire)

left to right direction

:Secrétaire: as secretaire

rectangle "SANTE SN" {
  rectangle "Authentification" {
    usecase "Se connecter" as UC_S_Login
    usecase "Recuperer mot de passe" as UC_S_Recovery
  }

  rectangle "Demandes RDV" {
    usecase "Consulter demandes en attente" as UC_S_ListDemandes
    usecase "Verifier disponibilite demande" as UC_S_CheckDisponibilite
    usecase "Approuver/Valider demande" as UC_S_ApproveDemande
    usecase "Refuser/Rejeter demande" as UC_S_RejectDemande
  }

  rectangle "Rendez-vous / Agenda" {
    usecase "Consulter agenda" as UC_S_ViewAgenda
    usecase "Annuler un rendez-vous" as UC_S_CancelRdv
  }

  rectangle "Paiements" {
    usecase "Suivre paiements" as UC_S_PaymentTracking
    usecase "Telecharger facture" as UC_S_DownloadInvoice
  }

  rectangle "Communication" {
    usecase "Lire notifications" as UC_S_Notifications
  }
}

secretaire --> UC_S_Login
secretaire --> UC_S_Recovery

secretaire --> UC_S_ListDemandes
secretaire --> UC_S_CheckDisponibilite
secretaire --> UC_S_ApproveDemande
secretaire --> UC_S_RejectDemande

secretaire --> UC_S_ViewAgenda
secretaire --> UC_S_CancelRdv

secretaire --> UC_S_PaymentTracking
secretaire --> UC_S_DownloadInvoice

secretaire --> UC_S_Notifications

UC_S_ApproveDemande .> UC_S_CheckDisponibilite : <<include>>
UC_S_RejectDemande .> UC_S_CheckDisponibilite : <<include>>
UC_S_ApproveDemande .> UC_S_Notifications : <<extend>>
UC_S_RejectDemande .> UC_S_Notifications : <<extend>>

@enduml

