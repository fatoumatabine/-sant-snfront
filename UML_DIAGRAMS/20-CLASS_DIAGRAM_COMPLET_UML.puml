@startuml 20-CLASS_DIAGRAM_COMPLET_UML

' ============================================================
' Diagramme de Classes Complet — SANTE_SN
' Multiplicités UML : 1, 0..1, *, 1..*
' Source : sante-sn-api-node/prisma/schema.prisma
' ============================================================

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam linetype ortho

skinparam class {
  BackgroundColor #F0F7FF
  BorderColor     #2563EB
  ArrowColor      #1E40AF
  FontName        Arial
  FontSize        11
  HeaderBackgroundColor #2563EB
  HeaderFontColor White
  HeaderFontSize  12
  HeaderFontStyle Bold
}

skinparam enum {
  BackgroundColor #FFF7ED
  BorderColor     #EA580C
  FontName        Arial
  FontSize        10
  HeaderBackgroundColor #EA580C
  HeaderFontColor White
}

skinparam classAttributeIconSize 0
skinparam note {
  BackgroundColor #FFFBEB
  BorderColor     #D97706
}

' ============================================================
'  ENUMERATIONS
' ============================================================

enum Role {
  patient
  medecin
  secretaire
  admin
}

enum StatutRendezVous {
  en_attente
  confirme
  termine
  annule
  paye
}

enum TypeRendezVous {
  en_ligne
  presentiel
  prestation
}

enum StatutConsultation {
  en_attente
  en_cours
  termine
}

enum StatutPaiement {
  en_attente
  paye
  echoue
  rembourse
}

enum StatutPrestation {
  en_attente
  en_cours
  termine
}

' ============================================================
'  CLASSES
' ============================================================

class User {
  + id : Int <<PK>>
  + email : String <<unique>>
  + password : String
  + name : String
  + avatarUrl : String?
  + role : Role
  + emailVerifiedAt : DateTime?
  + rememberToken : String?
  + isArchived : Boolean
  + archivedAt : DateTime?
  + createdAt : DateTime
  + updatedAt : DateTime
}

class Patient {
  + id : Int <<PK>>
  + userId : Int <<FK, unique>>
  + nom : String
  + prenom : String
  + telephone : String <<unique>>
  + date_naissance : DateTime?
  + adresse : String?
  + groupe_sanguin : String?
  + diabete : Boolean
  + hypertension : Boolean
  + hepatite : Boolean
  + autres_pathologies : String?
  + isArchived : Boolean
  + archivedAt : DateTime?
  + createdAt : DateTime
  + updatedAt : DateTime
}

class Medecin {
  + id : Int <<PK>>
  + userId : Int <<FK, unique>>
  + nom : String
  + prenom : String
  + specialite : String
  + telephone : String
  + adresse : String?
  + tarif_consultation : Float
  + isArchived : Boolean
  + archivedAt : DateTime?
  + createdAt : DateTime
  + updatedAt : DateTime
}

class Secretaire {
  + id : Int <<PK>>
  + userId : Int <<FK, unique>>
  + medecinId : Int? <<FK>>
  + nom : String
  + prenom : String
  + telephone : String
  + isArchived : Boolean
  + archivedAt : DateTime?
  + createdAt : DateTime
  + updatedAt : DateTime
}

class RendezVous {
  + id : Int <<PK>>
  + numero : String <<unique, cuid>>
  + date : DateTime
  + heure : String
  + patientId : Int <<FK>>
  + medecinId : Int <<FK>>
  + type : TypeRendezVous
  + statut : StatutRendezVous
  + urgent_ia : Boolean
  + motif : String?
  + raison_refus : String?
  + prestation_type : String?
  + createdAt : DateTime
  + updatedAt : DateTime
}

class RendezVousTransitionLog {
  + id : Int <<PK>>
  + rendezVousId : Int <<FK>>
  + fromStatut : StatutRendezVous?
  + toStatut : StatutRendezVous
  + actorRole : Role?
  + actorUserId : Int?
  + reason : String?
  + metadata : Json?
  + createdAt : DateTime
}

class Consultation {
  + id : Int <<PK>>
  + rendezVousId : Int? <<FK, unique>>
  + patientId : Int <<FK>>
  + medecinId : Int <<FK>>
  + date : DateTime
  + heure : String
  + type : String
  + statut : StatutConsultation
  + constantes : Json?
  + diagnostic : String?
  + observations : String?
  + isArchived : Boolean
  + archivedAt : DateTime?
  + createdAt : DateTime
  + updatedAt : DateTime
}

class ConsultationPresence {
  + id : Int <<PK>>
  + consultationId : Int <<FK>>
  + role : Role
  + userId : Int
  + lastSeenAt : DateTime
  + createdAt : DateTime
  + updatedAt : DateTime
  .. unique(consultationId, role) ..
}

class Ordonnance {
  + id : Int <<PK>>
  + consultationId : Int <<FK, unique>>
  + patientId : Int <<FK>>
  + medecinId : Int <<FK>>
  + contenu : String
  + date_creation : DateTime
  + isArchived : Boolean
  + archivedAt : DateTime?
  + createdAt : DateTime
  + updatedAt : DateTime
}

class Medicament {
  + id : Int <<PK>>
  + nom : String
  + forme : String
  + dosage : String
  + createdAt : DateTime
  + updatedAt : DateTime
}

class MedicamentOnOrdonnance {
  + ordonnanceId : Int <<PK, FK>>
  + medicamentId : Int <<PK, FK>>
  + posologie : String
  + duree : String
  + quantite : Int
}

class Paiement {
  + id : Int <<PK>>
  + patientId : Int <<FK>>
  + rendezVousId : Int <<FK, unique>>
  + montant : Float
  + methode : String
  + statut : StatutPaiement
  + transactionId : String?
  + date_paiement : DateTime?
  + isArchived : Boolean
  + archivedAt : DateTime?
  + createdAt : DateTime
  + updatedAt : DateTime
}

class Prestation {
  + id : Int <<PK>>
  + consultationId : Int? <<FK>>
  + patientId : Int <<FK>>
  + type : String
  + statut : StatutPrestation
  + resultat : String?
  + date_realisation : DateTime?
  + isArchived : Boolean
  + archivedAt : DateTime?
  + createdAt : DateTime
  + updatedAt : DateTime
}

class CreneauDisponible {
  + id : Int <<PK>>
  + medecinId : Int <<FK>>
  + jour : Int
  + heure : String
  + actif : Boolean
  .. unique(medecinId, jour, heure) ..
}

class Notification {
  + id : Int <<PK>>
  + userId : Int <<FK>>
  + titre : String
  + message : String
  + lu : Boolean
  + isArchived : Boolean
  + archivedAt : DateTime?
  + createdAt : DateTime
}

class ChatThread {
  + id : Int <<PK>>
  + participantAUserId : Int <<FK>>
  + participantBUserId : Int <<FK>>
  + lastMessageAt : DateTime
  + createdAt : DateTime
  + updatedAt : DateTime
  .. unique(participantAUserId, participantBUserId) ..
}

class ChatMessage {
  + id : Int <<PK>>
  + threadId : Int <<FK>>
  + senderUserId : Int <<FK>>
  + content : String
  + readAt : DateTime?
  + createdAt : DateTime
}

class PatientTriageEvaluation {
  + id : Int <<PK>>
  + patientId : Int <<FK>>
  + responses : Json
  + niveau : String
  + urgent : Boolean
  + specialiteConseillee : String?
  + recommandations : Json
  + redFlags : Json
  + needsHumanReview : Boolean
  + orientation : String
  + aiModel : String?
  + createdAt : DateTime
}

class AppSetting {
  + id : Int <<PK>>
  + key : String <<unique>>
  + value : Json
  + createdAt : DateTime
  + updatedAt : DateTime
}

class UserSetting {
  + id : Int <<PK>>
  + userId : Int <<FK, unique>>
  + value : Json
  + createdAt : DateTime
  + updatedAt : DateTime
}

' ============================================================
'  RELATIONS AVEC MULTIPLICITES UML
' ============================================================

' --- User → profils (1 vers 0..1) ---
User "1" -- "0..1" Patient       : < possède
User "1" -- "0..1" Medecin       : < possède
User "1" -- "0..1" Secretaire    : < possède
User "1" -- "0..1" UserSetting   : < configure

' --- User → Notification (1 vers *) ---
User "1" --o{ Notification : < reçoit

' --- User → Chat (1 vers *) ---
User "1" --o{ ChatThread : "participantA >"
User "1" --o{ ChatThread : "< participantB"
User "1" --o{ ChatMessage : < envoie

' --- Secretaire → Medecin (0..* vers 0..1) ---
Secretaire "0..*" }o-- "0..1" Medecin : < rattachée à

' --- Patient → RendezVous, Consultations, etc. (1 vers *) ---
Patient "1" --o{ RendezVous               : < demande
Patient "1" --o{ Consultation             : < participe à
Patient "1" --o{ Paiement                 : < effectue
Patient "1" --o{ Prestation               : < bénéficie de
Patient "1" --o{ Ordonnance               : < reçoit
Patient "1" --o{ PatientTriageEvaluation  : < évalué par IA

' --- Medecin → RendezVous, Consultations, etc. (1 vers *) ---
Medecin "1" --o{ RendezVous               : < conduit
Medecin "1" --o{ Consultation             : < réalise
Medecin "1" --o{ Ordonnance               : < rédige
Medecin "1" --o{ CreneauDisponible        : < définit

' --- RendezVous (1 vers 0..1) ---
RendezVous "1" -- "0..1" Consultation  : < génère
RendezVous "1" -- "0..1" Paiement      : < associé à

' --- RendezVous → Logs (1 vers *) ---
RendezVous "1" --o{ RendezVousTransitionLog : < historique

' --- Consultation (1 vers 0..1 / 1 vers *) ---
Consultation "1" -- "0..1" Ordonnance          : < produit
Consultation "1" --o{ Prestation               : < comprend
Consultation "1" --o{ ConsultationPresence     : < suit

' --- Ordonnance → Médicaments (many-to-many via pivot) ---
Ordonnance  "1" --o{ MedicamentOnOrdonnance : < contient
Medicament  "1" --o{ MedicamentOnOrdonnance : < prescrit dans

' --- ChatThread → Messages ---
ChatThread "1" --o{ ChatMessage : < contient

' ============================================================
'  DEPENDANCES ENUM
' ============================================================

User        ..[#EA580C]> Role              : role
RendezVous  ..[#EA580C]> StatutRendezVous : statut
RendezVous  ..[#EA580C]> TypeRendezVous   : type
RendezVousTransitionLog ..[#EA580C]> StatutRendezVous : from/toStatut
RendezVousTransitionLog ..[#EA580C]> Role              : actorRole
Consultation ..[#EA580C]> StatutConsultation : statut
Paiement     ..[#EA580C]> StatutPaiement     : statut
Prestation   ..[#EA580C]> StatutPrestation   : statut
ConsultationPresence ..[#EA580C]> Role        : role

@enduml
